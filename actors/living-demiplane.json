  "items": [
    {
      "name": "Dimensional Form",
      "type": "feat",
      "system": {
        "description": {
          "value": "Can enter another creature's space and vice versa. Can move through spaces as narrow as 1 inch without squeezing. Can't detach from solid surfaces. Destroyed if it has no surface to attach to."
        }
      }
    },
    {
      "name": "Extradimensional Chamber",
      "type": "feat",
      "system": {
        "description": {
          "value": "When entering a creature's space for the first time on a turn, that creature must succeed DC 10 Dexterity save or be pulled into an unfurnished 30-ft-cube stone chamber. No exits except via plane shift. Creatures inside can't affect the living spell but can damage the chamber (each 5-ft section: AC 17, 50 hp, immune to poison/psychic/nonmagical physical)."
        }
      }
    },
    {
      "name": "Magic Resistance",
      "type": "feat",
      "system": {
        "description": {
          "value": "Advantage on saving throws against spells and other magical effects."
        }
      }
    },
    {
      "name": "Planar Destruction",
      "type": "feat",
      "system": {
        "description": {
          "value": "Destroyed when it or a 5-ft section of its chamber is reduced to 0 hp, or when it has no surface to attach to. Contents of chamber expelled when destroyed."
        }
      }
    }
  ],
